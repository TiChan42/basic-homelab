# ============================================
# Traefik Static Configuration – managed by Ansible
# ============================================

# --- Global settings ---
global:
  checkNewVersion: false
  sendAnonymousUsage: false

# --- Entrypoints ---
entryPoints:
  web:
    address: ":{{ service_backend_port }}"
{% if traefik_https_enabled | default(true) | bool %}
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
{% endif %}
  websecure:
    address: ":{{ traefik_https_port }}"
  traefik:
    address: ":{{ traefik_dashboard_port }}"

# --- API / Dashboard ---
api:
  dashboard: {{ traefik_dashboard_enabled | default(true) | lower }}
  insecure: {{ traefik_dashboard_insecure | default(true) | lower }}
{% if not (traefik_dashboard_insecure | default(true) | bool) %}
  # When insecure is false, dashboard is served via router with auth middleware
{% endif %}

ping:
  entryPoint: traefik

# --- Providers ---
providers:
  file:
    directory: /etc/traefik/dynamic
    watch: true

{% if traefik_https_enabled | default(true) | bool and (traefik_tls_provider | default('letsencrypt')) == 'letsencrypt' %}
certificatesResolvers:
  letsencrypt:
    acme:
      email: "{{ traefik_letsencrypt_email }}"
      storage: /etc/traefik/acme/acme.json
      caServer: "{{ traefik_letsencrypt_ca_server | default('https://acme-v02.api.letsencrypt.org/directory') }}"
      httpChallenge:
        entryPoint: web
{% endif %}

# --- Logging ---
log:
  level: "{{ traefik_log_level | default('INFO') }}"

accessLog: {}
